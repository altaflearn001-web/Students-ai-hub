{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information including preferences and profile photo.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The URL to the user's profile photo." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "Timetable": {
      "title": "Timetable",
      "description": "Stores the analyzed timetable data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner of the timetable." },
        "data": { "type": "object", "description": "The structured timetable data (days and slots)." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the timetable was last updated." }
      },
      "required": ["uid", "data"]
    },
    "Todo": {
      "title": "To-Do Item",
      "description": "A task in the user's to-do list.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner of the task." },
        "text": { "type": "string", "description": "The task description." },
        "completed": { "type": "boolean", "description": "Whether the task is completed." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the task was created." }
      },
      "required": ["uid", "text", "completed"]
    },
    "FinanceRecord": {
      "title": "Finance Record",
      "description": "A record of income or expense in INR.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner of the record." },
        "amount": { "type": "number", "description": "The amount in INR." },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "The type of record." },
        "category": { "type": "string", "description": "The category (e.g., Food, Rent, Salary)." },
        "description": { "type": "string", "description": "A brief description." },
        "date": { "type": "string", "format": "date-time", "description": "When the transaction occurred." }
      },
      "required": ["uid", "amount", "type", "date"]
    },
    "Note": {
      "title": "AI Note",
      "description": "AI generated notes and summaries.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner of the note." },
        "title": { "type": "string", "description": "The title of the note." },
        "content": { "type": "string", "description": "The original content or source text." },
        "summary": { "type": "string", "description": "The AI generated summary." },
        "questions": { "type": "array", "items": { "type": "string" }, "description": "Important questions generated by AI." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the note was generated." }
      },
      "required": ["uid", "title", "summary"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "UserProfile", "description": "User profiles." },
    "/timetables/{uid}": { "schema": "Timetable", "description": "User timetables." },
    "/todos/{todoId}": { "schema": "Todo", "description": "User to-do items." },
    "/finances/{recordId}": { "schema": "FinanceRecord", "description": "User finance records." },
    "/notes/{noteId}": { "schema": "Note", "description": "User AI notes." }
  }
}
